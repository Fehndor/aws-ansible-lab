# -------------------------------------------------------
# terraform.tfvars
# Fill in your own values here before running terraform apply
# DO NOT commit this file to GitHub if it contains real secrets!
# Add terraform.tfvars to your .gitignore
# -------------------------------------------------------

aws_region   = "eu-central-1"
project_name = "ansible-lab"

# Your EC2 Key Pair name (create this in AWS Console > EC2 > Key Pairs first)
key_pair_name = "your-key-pair-name"

# Run 'curl ifconfig.me' to find your public IP, then add /32
your_ip_cidr = "YOUR.PUBLIC.IP.HERE/32"

# Change this to a strong password before deploying
postgres_password = "ChangeMe_AWX_2026!"

# These can stay as defaults unless you want to change them
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"
availability_zone   = "eu-central-1a"
awx_instance_type   = "t3.medium"
postgres_instance_type = "t3.small"
